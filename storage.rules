rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is admin or god
    function isAdmin() {
      return isAuthenticated() && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['god', 'admin'];
    }
    
    // Receipts folder - only authenticated users
    match /receipts/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Photos folder - only authenticated users
    match /photos/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Jobs folder - only authenticated users
    match /jobs/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }
    
    // Job Photos folder - only authenticated users
    match /job-photos/{allPaths=**} {
      allow read, write: if isAuthenticated();
    }
    
    // NDA Signatures - authenticated users can upload, anyone can read (for signing pages)
    match /nda-signatures/{filename} {
      allow read: if true;  // Public read for signing pages
      allow create: if isAuthenticated();  // Only authenticated can upload
      allow delete: if isAdmin();  // Only admin/god can delete
    }
    
    // Contract/Bid Signatures - similar to NDA
    match /signatures/{allPaths=**} {
      allow read: if true;  // Public read for signing pages
      allow create, update: if isAuthenticated();  // Only authenticated can upload
      allow delete: if isAdmin();  // Only admin/god can delete
    }

    // AI-generated landscape renderings — public read so signing page can show them
    match /ai-renderings/{allPaths=**} {
      allow read: if true;
      allow write: if false;  // Only writable via Admin SDK in Cloud Functions
    }

    // Default: deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}