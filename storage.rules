rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Job photos - allow anyone to read/write for now
    match /jobs/{jobId}/{allPaths=**} {
      allow read, write: if true; // TODO: Add authentication
      // Future: allow read, write: if request.auth != null;
      
      // Optional: Restrict file size to 10MB
      // allow write: if request.resource.size < 10 * 1024 * 1024;
      
      // Optional: Only allow images
      // allow write: if request.resource.contentType.matches('image/.*');
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
