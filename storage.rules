rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Receipts folder for expense tracking
    match /receipts/{allPaths=**} {
      allow read, write: if true; // TODO: Add authentication
    }
    
    // Allow all other storage access (no time limit!)
    match /{allPaths=**} {
      allow read, write: if true; // TODO: Add authentication
    }
  }
}