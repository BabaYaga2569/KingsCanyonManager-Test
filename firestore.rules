rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user has god or admin role (FIXED: handles null)
    function isGodOrAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['god', 'admin'];
    }
    
    // Helper function to check if user is god (owner) (FIXED: handles null)
    function isGod() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'god';
    }
    
    // NEW: Helper to check if accessing own data
    function isOwnData(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ============================================
    // USERS COLLECTION (Employee Account Manager)
    // ============================================
    match /users/{userId} {
      // CRITICAL: Anyone authenticated can READ all user documents
      // This is needed so the helper functions (isGod, isGodOrAdmin) can work
      allow read: if isAuthenticated();
      
      // Only god users can CREATE new users (FIXED: safer check)
      allow create: if isGod();
      
      // God can UPDATE any user
      allow update: if isGod();
      
      // FIXED: Users can UPDATE their OWN document for NDA signing (but cannot change role)
      // This checks: if role field is NOT in the update, OR if it's unchanged from original
      allow update: if isAuthenticated() && 
                      request.auth.uid == userId &&
                      (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
      
      // Only god users can DELETE users
      allow delete: if isGod();
    }
    
    // ============================================
    // BIDS COLLECTION - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /bids/{bidId} {
      allow read, write: if isGodOrAdmin();  // ✅ CREW BLOCKED
    }
    
    // ============================================
    // CONTRACTS COLLECTION - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /contracts/{contractId} {
      allow read: if true;  // ✅ Public for signing pages
      allow write: if isGodOrAdmin();  // ✅ CREW BLOCKED from editing
    }
    
    // ============================================
    // INVOICES COLLECTION - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /invoices/{invoiceId} {
      allow read: if true;  // ✅ Public for payment portal
      allow write: if isGodOrAdmin();  // ✅ CREW BLOCKED from editing
    }
    
    // ============================================
    // JOBS COLLECTION - ⚠️ CHANGED: READ FOR DROPDOWN
    // ============================================
    match /jobs/{jobId} {
      // ✅ CREW can READ job names for time clock dropdown
      allow read: if isAuthenticated();
      // ✅ Only ADMIN can create/edit jobs
      allow write: if isGodOrAdmin();
    }
    
    // ============================================
    // CUSTOMERS COLLECTION - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /customers/{customerId} {
      allow read, write: if isGodOrAdmin();  // ✅ CREW BLOCKED
    }
    
    // ============================================
    // EXPENSES COLLECTION - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /expenses/{expenseId} {
      allow read, write: if isGodOrAdmin();  // ✅ CREW BLOCKED
    }
    
    // ============================================
    // PAYMENTS COLLECTION - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /payments/{paymentId} {
      allow read, write: if isGodOrAdmin();  // ✅ CREW BLOCKED
    }
    
    // ============================================
    // CREW PAYMENTS COLLECTION (✅ ALREADY CORRECT - Payroll)
    // ============================================
    match /crew_payments/{paymentId} {
      // All authenticated users can read crew payments
      allow read: if isGodOrAdmin();  // ✅ CREW BLOCKED from seeing payroll
      
      // Only god/admin can create, update, delete crew payments
      allow create, update, delete: if isGodOrAdmin();
    }
    
    // ============================================
    // SCHEDULES COLLECTION - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /schedules/{scheduleId} {
      allow read, write: if isGodOrAdmin();  // ✅ CREW BLOCKED
    }
    
    // ============================================
    // SCHEDULE COLLECTION (Legacy) - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /schedule/{scheduleId} {
      allow read, write: if isGodOrAdmin();  // ✅ CREW BLOCKED
    }
    
    // ============================================
    // CALENDAR COLLECTION - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /calendar/{calendarId} {
      allow read, write: if isGodOrAdmin();  // ✅ CREW BLOCKED
    }
    
    // ============================================
    // TIME CLOCK COLLECTION - ⚠️ CHANGED: OWN DATA ONLY
    // ============================================
    match /timeClock/{timeClockId} {
      // ✅ CREW can only see their own time clock data
      allow read: if isOwnData(timeClockId) || isGodOrAdmin();
      allow create: if isAuthenticated() && request.auth.uid == timeClockId;
      allow update: if isOwnData(timeClockId) || isGodOrAdmin();
      allow delete: if isGodOrAdmin();
    }
    
    // ============================================
    // JOB TIME ENTRIES COLLECTION - ⚠️ CHANGED: OWN DATA ONLY
    // ============================================
    match /job_time_entries/{entryId} {
      // ✅ CREW can create their own time entries
      allow create: if isAuthenticated();
      
      // ✅ CREW can only read their own entries, ADMIN sees all
      allow read: if isAuthenticated() && 
                    (resource.data.userId == request.auth.uid || isGodOrAdmin());
      
      // ✅ CREW can update their own entries, ADMIN can update all
      allow update: if isAuthenticated() && 
                      (resource.data.userId == request.auth.uid || isGodOrAdmin());
      
      // Only god/admin can delete
      allow delete: if isGodOrAdmin();
    }
    
    // ============================================
    // NOTES COLLECTION - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /notes/{noteId} {
      allow read, write: if isGodOrAdmin();  // ✅ CREW BLOCKED
    }
    
    // ============================================
    // CREW COLLECTION (✅ ALREADY CORRECT - Legacy)
    // ============================================
    match /crew/{crewId} {
      allow read, write: if isGodOrAdmin();
    }
    
    // ============================================
    // CREWS COLLECTION (✅ ALREADY CORRECT)
    // ============================================
    match /crews/{crewId} {
      allow read: if true;  // ✅ Public for NDA signing
      allow write: if isGodOrAdmin();
    }
    
    // ============================================
    // EQUIPMENT COLLECTION - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /equipment/{equipmentId} {
      allow read, write: if isGodOrAdmin();  // ✅ CREW BLOCKED
    }
    
    // ============================================
    // NDA SIGNATURES COLLECTION (✅ ALREADY CORRECT)
    // ============================================
    match /ndaSignatures/{signatureId} {
      // God and Admin can read all
      allow read: if isGodOrAdmin();
      
      // Employees can create their own signature
      allow create: if isAuthenticated() && request.auth.uid == signatureId;
      
      // Employees can read their own signature
      allow read: if isAuthenticated() && request.auth.uid == signatureId;
    }
    
    // ============================================
    // NOTIFICATIONS COLLECTION - ⚠️ CHANGED: OWN DATA ONLY
    // ============================================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();  // Everyone can see notifications
      allow write: if isGodOrAdmin();  // Only admin creates notifications
    }
    
    // ============================================
    // NOTIFICATION COUNTS COLLECTION (✅ ALREADY CORRECT)
    // ============================================
    match /notificationCounts/{userId} {
      allow read, write: if isAuthenticated();
    }
    
    // ============================================
    // SETTINGS COLLECTION (✅ ALREADY CORRECT)
    // ============================================
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isGodOrAdmin();
    }
    
    // ============================================
    // MAINTENANCE CONTRACTS COLLECTION - ⚠️ CHANGED: ADMIN ONLY
    // ============================================
    match /maintenance_contracts/{contractId} {
      allow read, write: if isGodOrAdmin();  // ✅ CREW BLOCKED
    }
    
    // ============================================
    // NOTIFICATION SETTINGS COLLECTION (NEW - SMS)
    // ============================================
    match /notification_settings/{settingId} {
      allow read: if isGodOrAdmin();
      allow write: if isGod();  // Only god can configure SMS settings
    }
    
    // ============================================
    // NOTIFICATIONS LOG COLLECTION (NEW - SMS History)
    // ============================================
    match /notifications_log/{logId} {
      allow read: if isGodOrAdmin();  // God/Admin can view SMS history
      allow create: if isAuthenticated();  // System can log SMS sends
    }
  }
}
