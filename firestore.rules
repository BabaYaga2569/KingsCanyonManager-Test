rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user has god or admin role
    function isGodOrAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['god', 'admin'];
    }
    
    // Helper function to check if user is god (owner)
    function isGod() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'god';
    }
    
    // Helper to check if accessing own data
    function isOwnData(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ============================================
    // USERS COLLECTION (Employee Account Manager)
    // ============================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isGod();
      allow update: if isGod();
      allow update: if isAuthenticated() && 
                      request.auth.uid == userId &&
                      (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
      allow delete: if isGod();
    }
    
    // ============================================
    // 🔐 BIDS COLLECTION
    // Public bid signing now goes through secure Cloud Functions.
    // Direct Firestore access is admin-only.
    // ============================================
    match /bids/{bidId} {
      allow read, write: if isGodOrAdmin();
    }
    
    // ============================================
    // 🔐 CONTRACTS COLLECTION
    // Admins have full access.
    // Public customers can read/sign contracts that have a signingToken
    // (meaning Darren intentionally sent them a signing link).
    // Write is restricted to signature fields only for unauthenticated users.
    // ============================================
    match /contracts/{contractId} {
      // Admins: full access
      allow read, write: if isGodOrAdmin();

      // Public read: only if the contract has a signingToken set
      // (unguessable contractId + token = safe for public signing page)
      allow read: if resource.data.signingToken != null
                  && resource.data.signingToken.size() > 0;

      // Public update: only allowed on signature fields
      // Prevents customers from modifying amount, clientName, etc.
      allow update: if resource.data.signingToken != null
                    && resource.data.signingToken.size() > 0
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['clientSignature', 'clientSignedAt',
                                   'contractorSignature', 'contractorSignedAt',
                                   'status', 'lastUpdated']);
    }
    
    // ============================================
    // 🔐 INVOICES COLLECTION
    // ============================================
    match /invoices/{invoiceId} {
      // Read: public (invoice IDs are unguessable - needed for payment portal)
      allow read: if true;
      
      // Write: only admin
      allow write: if isGodOrAdmin();
      
      // Update: admin only
      allow update: if isGodOrAdmin();
    }
    
    // ============================================
    // JOBS COLLECTION - READ FOR DROPDOWN
    // ============================================
    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isGodOrAdmin();
    }
    
    // ============================================
    // CUSTOMERS COLLECTION - ADMIN ONLY
    // ============================================
    match /customers/{customerId} {
      allow read: if isAuthenticated();        // crew needs this for GPS address lookup
      allow write: if isGodOrAdmin();
    }
    
    // ============================================
    // EXPENSES COLLECTION - ADMIN ONLY
    // ============================================
    match /expenses/{expenseId} {
      allow read, write: if isGodOrAdmin();
    }
    
    // ============================================
    // PAYMENTS COLLECTION - ADMIN ONLY
    // ============================================
    match /payments/{paymentId} {
      // Read: public (needed for payment history on payment portal)
      allow read: if true;
      allow write: if isGodOrAdmin();
    }
    
    // ============================================
    // CREW PAYMENTS COLLECTION - Payroll
    // ============================================
    match /crew_payments/{paymentId} {
      allow read: if isGodOrAdmin();
      allow create, update, delete: if isGodOrAdmin();
    }
    
    // ============================================
    // SCHEDULES COLLECTION - ADMIN ONLY
    // ============================================
    match /schedules/{scheduleId} {
      allow read, write: if isGodOrAdmin();
    }
    
    // ============================================
    // SCHEDULE COLLECTION (Legacy) - ADMIN ONLY
    // ============================================
    match /schedule/{scheduleId} {
      allow read, write: if isGodOrAdmin();
    }
    
    // ============================================
    // CALENDAR COLLECTION - ADMIN ONLY
    // ============================================
    match /calendar/{calendarId} {
      allow read, write: if isGodOrAdmin();
    }
    
    // ============================================
    // TIME CLOCK COLLECTION - OWN DATA ONLY
    // ============================================
    match /timeClock/{timeClockId} {
      allow read: if isOwnData(timeClockId) || isGodOrAdmin();
      allow create: if isAuthenticated() && request.auth.uid == timeClockId;
      allow update: if isOwnData(timeClockId) || isGodOrAdmin();
      allow delete: if isGodOrAdmin();
    }
    
    // ============================================
    // JOB TIME ENTRIES COLLECTION
    // ============================================
    match /job_time_entries/{entryId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && 
                    (resource.data.crewId == request.auth.uid || isGodOrAdmin());
      allow update: if isAuthenticated() && 
                      (resource.data.crewId == request.auth.uid || isGodOrAdmin());
      allow delete: if isGodOrAdmin();
    }
    
    // ============================================
    // NOTES COLLECTION - ADMIN ONLY
    // ============================================
    match /notes/{noteId} {
      allow read, write: if isGodOrAdmin();
    }
    
    // ============================================
    // CREW COLLECTION (Legacy)
    // ============================================
    match /crew/{crewId} {
      allow read, write: if isGodOrAdmin();
    }
    
    // ============================================
    // CREWS COLLECTION
    // ============================================
    match /crews/{crewId} {
      allow read: if true;  // Public for NDA signing
      allow write: if isGodOrAdmin();
    }
    
    // ============================================
    // EQUIPMENT COLLECTION - ADMIN ONLY
    // ============================================
    match /equipment/{equipmentId} {
      allow read, write: if isGodOrAdmin();
    }
    
    // ============================================
    // NDA SIGNATURES COLLECTION
    // ============================================
    match /ndaSignatures/{signatureId} {
      allow read: if isGodOrAdmin();
      allow create: if isAuthenticated() && request.auth.uid == signatureId;
      allow read: if isAuthenticated() && request.auth.uid == signatureId;
    }
    
    // ============================================
    // NOTIFICATIONS COLLECTION - OWN DATA ONLY
    // ============================================
    match /notifications/{notificationId} {
      allow read: if isAuthenticated();
      allow write: if isGodOrAdmin();
    }
    
    // ============================================
    // NOTIFICATION COUNTS COLLECTION
    // ============================================
    match /notificationCounts/{userId} {
      allow read, write: if isAuthenticated();
    }
    
    // ============================================
    // SETTINGS COLLECTION
    // ============================================
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isGodOrAdmin();
    }
    
    // ============================================
    // MAINTENANCE CONTRACTS COLLECTION - ADMIN ONLY
    // ============================================
    match /maintenance_contracts/{contractId} {
      allow read, write: if isGodOrAdmin();
    }
    
    // ============================================
    // NOTIFICATION SETTINGS COLLECTION (SMS)
    // ============================================
    match /notification_settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isGod();
    }
    
    // ============================================
    // NOTIFICATIONS LOG COLLECTION (SMS History)
    // ============================================
    match /notifications_log/{logId} {
      allow read: if isGodOrAdmin();
      allow create: if isAuthenticated();
    }

    // ============================================
    // INVITES COLLECTION - Employee invite tokens
    // Public read needed so InviteSignup page can
    // validate the token without being logged in.
    // All writes go through Cloud Functions (Admin SDK).
    // ============================================
    match /invites/{token} {
      allow read: if true;
      allow write: if false;
    }

    // ============================================
    // EMAIL LOG COLLECTION
    // ============================================
    match /email_log/{logId} {
      allow read: if isGodOrAdmin();
      allow create: if isAuthenticated();
    }
  }
}